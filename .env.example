OPENAI_API_KEY=sk-proj-

# (Optional - LangSmith is optional if you want observability)
LANGSMITH_API_KEY=lsv2_pt_
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_PROJECT=llamabot-open-source

# PostgreSQL database for user authentication and LangGraph checkpoints
# By default, checkpointer uses this database (llamabot_production)
# This consolidates all LlamaBot data in one place
AUTH_DB_URI=postgresql://user:password@db:5432/llamabot

# (Optional) Override checkpointer database if you want it separate from auth
# Falls back to: CHECKPOINTER_DB_URI -> LEONARDO_DB_URI -> AUTH_DB_URI -> DB_URI
CHECKPOINTER_DB_URI=

# (Legacy) Old DB_URI - now used as fallback for checkpointer
DB_URI=postgresql://user:password@db:5432/llamapress

# Checkpoint cleanup configuration:
# - After each successful message, intermediate checkpoints are cleaned up immediately
# - Every 24 hours, stale threads (inactive for CHECKPOINT_STALE_MINUTES) are cleaned
# - Only the latest checkpoint per thread is kept (for thread resumption)
CHECKPOINT_STALE_MINUTES=30

# (Optional if you're using LlamaPress)
LLAMAPRESS_API_URL="localhost:3000"

LLAMABOT_VERSION=0.2.19